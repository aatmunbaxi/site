@online{zhangHierarchyConstructionNonabelian2025,
  title = {Hierarchy Construction for Non-Abelian Fractional Quantum {{Hall}} States via Anyon Condensation},
  author = {Zhang, Carolyn and Vishwanath, Ashvin and Wen, Xiao-Gang},
  date = {2025-03-18},
  eprint = {2406.12068},
  eprinttype = {arXiv},
  eprintclass = {cond-mat},
  doi = {10.48550/arXiv.2406.12068},
  url = {http://arxiv.org/abs/2406.12068},
  urldate = {2025-04-07},
  abstract = {For a given parent fractional quantum Hall (FQH) state at filling fraction \$\textbackslash nu\$, the hierarchy construction produces FQH states at nearby filling fractions \$\textbackslash\{\textbackslash nu\_n\textbackslash\}\$ by condensing minimally charged quasiholes or quasiparticles of the parent state into their own FQH states. The hierarchy construction has been useful for relating families of FQH states and for the experimental identification of the topological order of parent states via the presence of daughter states. We reinterpret the hierarchy construction as a two-step procedure: stacking with a second FQH state and condensing a condensable algebra of bosons. This two-step procedure can be applied to both abelian and non-abelian FQH states, and it does not require calculations with a wavefunction. We show this construction reproduces the hierarchies for the Laughlin and Pfaffian states, and can be applied further to propose hierarchies for various non-abelian FQH states.},
  pubstate = {prepublished},
  keywords = {Condensed Matter - Strongly Correlated Electrons},
  file = {/home/aatmun/Documents/pdfs/Articles/Zhang et al. - 2025 - Hierarchy construction for non-abelian fractional quantum Hall states via anyon condensation.pdf;/home/aatmun/Documents/pdfs/Articles/Zhang et al. - 2025 - Hierarchy construction for non-abelian fractional.pdf;/home/aatmun/Documents/zotero/storage/6YSDHPKW/2406.html}
}

