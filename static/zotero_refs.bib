}

@article{nataleFaithfulSimpleObjects2013,
  title = {Faithful Simple Objects, Orders and Gradings of Fusion Categories},
  author = {Natale, Sonia},
  date = {2013-04-30},
  journaltitle = {Algebraic \& Geometric Topology},
  shortjournal = {Algebr. Geom. Topol.},
