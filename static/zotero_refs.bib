@article{bischoffSpontaneousSymmetryBreaking2019,
  title = {Spontaneous Symmetry Breaking from Anyon Condensation},
  author = {Bischoff, Marcel and Jones, Corey and Lu, Yuan-Ming and Penneys, David},
  date = {2019-02-12},
  journaltitle = {Journal of High Energy Physics},
  shortjournal = {J. High Energ. Phys.},
  volume = {2019},
  number = {2},
  pages = {62},
  issn = {1029-8479},
  doi = {10.1007/JHEP02(2019)062},
  url = {https://doi.org/10.1007/JHEP02(2019)062},
  urldate = {2025-10-01},
  abstract = {In a physical system undergoing a continuous quantum phase transition, spontaneous symmetry breaking occurs when certain symmetries of the Hamiltonian fail to be preserved in the ground state. In the traditional Landau theory, a symmetry group can break down to any subgroup. However, this no longer holds across a continuous phase transition driven by anyon condensation in symmetry enriched topological orders (SETOs). For a SETO described by a G-crossed braided extension \$\$ \textbackslash mathcal\{C\}\textbackslash subseteq \{\textbackslash mathcal\{C\}\}\_G\textasciicircum\{\textbackslash times \} \$\$, we show that physical considerations require that a connected étale algebra A ∈ \$\$ \textbackslash mathcal\{C\} \$\$admit a G-equivariant algebra structure for symmetry to be preserved under condensation of A. Given any categorical action G → EqBr(\$\$ \textbackslash mathcal\{C\} \$\$) such that g(A) ≅ A for all g ∈ G, we show there is a short exact sequence whose splittings correspond to G-equivariant algebra structures. The non-splitting of this sequence forces spontaneous symmetry breaking under condensation of A, while inequivalent splittings of the sequence correspond to different SETOs resulting from the anyon-condensation transition. Furthermore, we show that if symmetry is preserved, there is a canonically associated SETO of \$\$ \{\textbackslash mathcal\{C\}\}\_A\textasciicircum\{\textbackslash mathrm\{loc\}\} \$\$, and gauging this symmetry commutes with anyon condensation.},
  langid = {english},
  keywords = {Anyons,Spontaneous Symmetry Breaking,Topological Field Theories,Topological States of Matter},
  file = {/home/aatmun/Documents/pdfs/Articles/Bischoff et al. - 2019 - Spontaneous symmetry breaking from anyon condensat.pdf;/home/aatmun/Documents/pdfs/Articles/Bischoff et al. - 2019 - Spontaneous symmetry breaking from anyon condensat.pdf;/home/aatmun/Documents/pdfs/Articles/Bischoff et al. - 2019 - Spontaneous symmetry breaking from anyon condensation.pdf}
}

@article{bockenhauer$a$inductionChiralGenerators1999,
  title = {On \$α\$-Induction, Chiral Generators and Modular Invariants for Subfactors},
  author = {Böckenhauer, J. and Evans, D. E. and Kawahigashi, Y.},
  date = {1999-12-30},
  journaltitle = {Communications in Mathematical Physics},
  shortjournal = {Communications in Mathematical Physics},
  volume = {208},
  number = {2},
  eprint = {math/9904109},
  eprinttype = {arXiv},
  pages = {429--487},
  issn = {0010-3616, 1432-0916},
  doi = {10.1007/s002200050765},
  url = {http://arxiv.org/abs/math/9904109},
  urldate = {2025-09-30},
  abstract = {We consider a type III subfactor \$N\textbackslash subset M\$ of finite index with a finite system of braided \$N\$-\$N\$ morphisms which includes the irreducible constituents of the dual canonical endomorphism. We apply \$\textbackslash alpha\$-induction and, developing further some ideas of Ocneanu, we define chiral generators for the double triangle algebra. Using a new concept of intertwining braiding fusion relations, we show that the chiral generators can be naturally identified with the \$\textbackslash alpha\$-induced sectors. A matrix \$Z\$ is defined and shown to commute with the S- and T-matrices arising from the braiding. If the braiding is non-degenerate, then \$Z\$ is a ``modular invariant mass matrix'' in the usual sense of conformal field theory. We show that in that case the fusion rule algebra of the dual system of \$M\$-\$M\$ morphisms is generated by the images of both kinds of \$\textbackslash alpha\$-induction, and that the structural information about its irreducible representations is encoded in the mass matrix \$Z\$. Our analysis sheds further light on the connection between (the classifications of) modular invariants and subfactors, and we will construct and analyze modular invariants from \$SU(n)\_k\$ loop group subfactors in a forthcoming publication, including the treatment of all \$SU(2)\_k\$ modular invariants.},
  keywords = {High Energy Physics - Theory,Mathematical Physics,Mathematics - Mathematical Physics,Mathematics - Operator Algebras,Mathematics - Quantum Algebra,Mathematics - Representation Theory},
  file = {/home/aatmun/Documents/pdfs/Articles/Böckenhauer et al. - 1999 - On $α$-induction, chiral generators and modular in.pdf;/home/aatmun/Documents/pdfs/Articles/Böckenhauer et al. - 1999 - On $α$-induction, chiral generators and modular invariants for subfactors.pdf;/home/aatmun/Documents/zotero/storage/YSX8S68E/9904109.html}
}

@article{bockenhauerChiralStructureModular2000,
  title = {Chiral Structure of Modular Invariants for Subfactors},
  author = {Böckenhauer, J. and Evans, D. E. and Kawahigashi, Y.},
  date = {2000-04-01},
  journaltitle = {Communications in Mathematical Physics},
  shortjournal = {Communications in Mathematical Physics},
  volume = {210},
  number = {3},
  eprint = {math/9907149},
  eprinttype = {arXiv},
  pages = {733--784},
  issn = {0010-3616, 1432-0916},
  doi = {10.1007/s002200050798},
  url = {http://arxiv.org/abs/math/9907149},
  urldate = {2026-02-27},
  abstract = {In this paper we further analyze modular invariants for subfactors, in particular the structure of the chiral induced systems of M-M morphisms. The relative braiding between the chiral systems restricts to a proper braiding on their ``ambichiral'' intersection, and we show that the ambichiral braiding is non-degenerate if the original braiding of the N-N morphisms is. Moreover, in this case the dimensions of the irreducible representations of the chiral fusion rule algebras are given by the chiral branching coefficients which describe the ambichiral contribution in the irreducible decomposition of alpha-induced sectors. We show that modular invariants come along naturally with several non-negative integer valued matrix representations of the original N-N Verlinde fusion rule algebra, and we completely determine their decomposition into its characters. Finally the theory is illustrated by various examples, including the treatment of all SU(2)\_k modular invariants, some SU(3) conformal inclusions and the chiral conformal Ising model.},
  keywords = {High Energy Physics - Theory,Mathematical Physics,Mathematics - Operator Algebras,Mathematics - Quantum Algebra,Mathematics - Representation Theory},
  file = {/home/aatmun/Documents/pdfs/Articles/Böckenhauer et al. - 2000 - Chiral structure of modular invariants for subfact.pdf;/home/aatmun/Documents/zotero/storage/3G7HKYXB/9907149.html}
}

