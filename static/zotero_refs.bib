  keywords = {Mathematics - Quantum Algebra},
  file = {/home/aatmun/Documents/pdfs/Articles/Delaney et al. - 2024 - $G$-crossed braided zesting 3.pdf;/home/aatmun/Documents/pdfs/Articles/Delaney et al. - 2024 - $G$-crossed braided zesting.pdf;/home/aatmun/Documents/pdfs/Articles/Delaney et al. - 2024 - $G$-crossed braided zesting.pdf}
