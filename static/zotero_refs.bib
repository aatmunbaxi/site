@online{martinParavorticesLoopBraid2026,
  title = {Paravortices: Loop Braid Representations with Both Generators Involutive},
  shorttitle = {Paravortices},
  author = {Martin, Paul P. and Rowell, Eric C. and Torzewska, Fiona},
  date = {2026-01-28},
  eprint = {2512.17830},
  eprinttype = {arXiv},
  eprintclass = {math},
  doi = {10.48550/arXiv.2512.17830},
  url = {http://arxiv.org/abs/2512.17830},
  urldate = {2026-02-14},
  abstract = {We first motivate the study of a certain quotient of the loop braid category, both for the mathematics underpinning recent approaches to topological quantum computation; and as a key example in non-semisimple higher representation theory. For reasons that will become clear, we call this quotient the mixed doubles category, \$MD\$. Then our main result is a theorem classifying all mixed doubles representations in rank-2. Each representation yields a mixed doubles group representation for every loop braid group \$LB\_n\$, and we are able to analyse the unified linear representation theory of many of these sequences of representations, using a mixture of very classical, classical, and new techniques. In particular this is a motivating example for the `glue' generalisation of charge-conserving representation theory (a form of rigid higher non-semisimplicity) introduced recently.},
  pubstate = {prepublished},
  keywords = {Mathematics - Quantum Algebra},
  file = {/home/aatmun/Documents/pdfs/Articles/Martin et al. - 2026 - Paravortices loop braid representations with both.pdf;/home/aatmun/Documents/zotero/storage/FV9WBKVM/2512.html}
}

@online{maurerComputingCenterFusion2024,
  title = {Computing the Center of a Fusion Category},
  author = {Mäurer, Fabian and Thiel, Ulrich},
  date = {2024-06-19},
  eprint = {2406.13438},
  eprinttype = {arXiv},
  eprintclass = {math-ph},
  url = {http://arxiv.org/abs/2406.13438},
  urldate = {2024-06-21},
  abstract = {We present a (Las Vegas) algorithm for explicitly computing the simple objects of the categorical (Drinfeld) center of a spherical fusion category. Our approach is based on decomposing the images of simple objects under the induction functor from the category to its center. We have implemented this algorithm in a general-purpose software framework TensorCategories.jl for tensor categories that we develop within the open-source computer algebra system OSCAR. While the required computations are still too heavy to investigate standard examples whose center is not yet known up to some equivalence, our algorithm has the advantage of determining explicit half-braidings for the simple central objects, avoiding abstract equivalences and the like. Furthermore, it also works over not necessarily algebraically closed fields, and this yields new explicit examples of non-split modular categories.},
  pubstate = {prepublished},
  keywords = {Mathematical Physics,Mathematics - Category Theory,Mathematics - Quantum Algebra,Mathematics - Representation Theory},
  file = {/home/aatmun/Documents/bib/pdfs/Mäurer_Thiel_2024_Computing the center of a fusion category.pdf}
}

