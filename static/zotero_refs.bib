@article{cuiGaugingSymmetryModular2016,
  title = {On {{Gauging Symmetry}} of {{Modular Categories}}},
  author = {Cui, Shawn X. and Galindo, César and Plavnik, Julia Yael and Wang, Zhenghan},
  date = {2016-12-01},
  journaltitle = {Communications in Mathematical Physics},
  shortjournal = {Commun. Math. Phys.},
  volume = {348},
