@article{izumiStructureSectorsAssociatedLongo2000,
  title = {The {{Structure}} of {{Sectors}}¶{{Associated}} with {{Longo}}–{{Rehren Inclusions}}¶{{I}}. {{General Theory}}},
  author = {Izumi, Masaki},
