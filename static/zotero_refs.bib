@book{etingofTensorCategories2016,
  title = {Tensor {{Categories}}},
  author = {Etingof, Pavel and Gelaki, Shlomo and Nikshych, Dmitri and Ostrik, Victor},
  date = {2016-08-05},
  eprint = {Z6XLDAAAQBAJ},
  eprinttype = {googlebooks},
  publisher = {American Mathematical Soc.},
  abstract = {Is there a vector space whose dimension is the golden ratio? Of course not—the golden ratio is not an integer! But this can happen for generalizations of vector spaces—objects of a tensor category. The theory of tensor categories is a relatively new field of mathematics that generalizes the theory of group representations. It has deep connections with many other fields, including representation theory, Hopf algebras, operator algebras, low-dimensional topology (in particular, knot theory), homotopy theory, quantum mechanics and field theory, quantum computation, theory of motives, etc. This book gives a systematic introduction to this theory and a review of its applications. While giving a detailed overview of general tensor categories, it focuses especially on the theory of finite tensor categories and fusion categories (in particular, braided and modular ones), and discusses the main results about them with proofs. In particular, it shows how the main properties of finite-dimensional Hopf algebras may be derived from the theory of tensor categories.  Many important results are presented as a sequence of exercises, which makes the book valuable for students and suitable for graduate courses. Many applications, connections to other areas, additional results, and references are discussed at the end of each chapter.},
  isbn = {978-1-4704-3441-0},
  langid = {english},
  pagetotal = {362},
  file = {/home/aatmun/Documents/pdfs/Etingof et al. - 2016 - Tensor Categories.pdf;/home/aatmun/Documents/pdfs/Etingof et al. - 2016 - Tensor Categories.pdf;/home/aatmun/Documents/pdfs/Reference Books/Etingof et al. - 2016 - Tensor Categories.pdf}
}

@online{etingofWeaklyGrouptheoreticalSolvable2009,
  title = {Weakly Group-Theoretical and Solvable Fusion Categories},
  author = {Etingof, Pavel and Nikshych, Dmitri and Ostrik, Victor},
  date = {2009-07-22},
  eprint = {0809.3031},
  eprinttype = {arXiv},
  eprintclass = {math},
  doi = {10.48550/arXiv.0809.3031},
  url = {http://arxiv.org/abs/0809.3031},
  urldate = {2025-02-17},
  abstract = {We introduce two new classes of fusion categories which are obtained by a certain procedure from finite groups - weakly group-theoretical categories and solvable categories. These are fusion categories that are Morita equivalent to iterated extensions (in the world of fusion categories) of arbitrary, respectively solvable finite groups. Weakly group-theoretical categories have integer dimension, and all known fusion categories of integer dimension are weakly group theoretical. Our main results are that a weakly group-theoretical category C has the strong Frobenius property (i.e., the dimension of any simple object in an indecomposable C-module category divides the dimension of C), and that any fusion category whose dimension has at most two prime divisors is solvable (a categorical analog of Burnside's theorem for finite groups). This has powerful applications to classification of fusion categories and semsisimple Hopf algebras of a given dimension. In particular, we show that any fusion category of integer dimension {$<$}84 is weakly group-theoretical (i.e. comes from finite group theory), and give a full classification of semisimple Hopf algebras of dimensions pqr and pq\textasciicircum 2, where p,q,r are distinct primes.},
  pubstate = {prepublished},
  keywords = {Mathematics - Category Theory,Mathematics - Quantum Algebra},
  file = {/home/aatmun/Documents/bib/pdfs/Etingof et al_2009_Weakly group-theoretical and solvable fusion categories.pdf;/home/aatmun/Documents/pdfs/Articles/Etingof et al. - 2009 - Weakly group-theoretical and solvable fusion categ.pdf;/home/aatmun/Documents/pdfs/Articles/Etingof et al. - 2009 - Weakly group-theoretical and solvable fusion categ.pdf;/home/aatmun/Documents/pdfs/Articles/Etingof et al. - 2009 - Weakly group-theoretical and solvable fusion categories 2.pdf;/home/aatmun/Documents/pdfs/Articles/Etingof et al. - 2009 - Weakly group-theoretical and solvable fusion categories.pdf;/home/aatmun/Documents/zotero/storage/BUXNL789/0809.html}
}

