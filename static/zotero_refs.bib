@online{muegerGaloisTheoryBraided1999,
  title = {Galois {{Theory}} for {{Braided Tensor Categories}} and the {{Modular Closure}}},
  author = {Mueger, Michael},
  date = {1999-10-05},
  eprint = {math/9812040},
  eprinttype = {arXiv},
  doi = {10.48550/arXiv.math/9812040},
  url = {http://arxiv.org/abs/math/9812040},
  urldate = {2026-01-14},
  abstract = {Given a braided tensor *-category C with conjugate (dual) objects and irreducible unit together with a full symmetric subcategory S we define a crossed product C\textbackslash rtimes S. This construction yields a tensor *-category with conjugates and an irreducible unit. (A *-category is a category enriched over Vect\_C with positive *-operation.) A Galois correspondence is established between intermediate categories sitting between C and C\textbackslash rtimes S and closed subgroups of the Galois group Gal(C\textbackslash rtimes S/C)=Aut\_C(C\textbackslash rtimes S) of C, the latter being isomorphic to the compact group associated to S by the duality theorem of Doplicher and Roberts. Denoting by D\textbackslash subset C the full subcategory of degenerate objects, i.e. objects which have trivial monodromy with all objects of C, the braiding of C extends to a braiding of C\textbackslash rtimes S iff S\textbackslash subset D. Under this condition C\textbackslash rtimes S has no degenerate objects iff S=D. If the original category C is rational (i.e. has only finitely many equivalence classes of irreducible objects) then the same holds for the new one. The category C\textbackslash rtimes D is called the modular closure of C since in the rational case it is modular, i.e. gives rise to a unitary representation of the modular group SL(2,Z). (In passing we prove that every braided tensor *-category with conjugates automatically is a ribbon category, i.e. has a twist.) If all simple objects of S have dimension one the structure of the category C\textbackslash rtimes S can be clarified quite explicitly in terms of group cohomology.},
  pubstate = {prepublished},
  keywords = {High Energy Physics - Theory,Mathematics - Category Theory},
  file = {/home/aatmun/Documents/pdfs/Articles/Mueger - 1999 - Galois Theory for Braided Tensor Categories and th.pdf;/home/aatmun/Documents/pdfs/Articles/Mueger - 1999 - Galois Theory for Braided Tensor Categories and the Modular Closure.pdf;/home/aatmun/Documents/zotero/storage/KPLEBES5/9812040.html}
}

@online{muegerStructureModularCategories2002,
  title = {On the {{Structure}} of {{Modular Categories}}},
  author = {Mueger, Michael},
  date = {2002-01-03},
  eprint = {math/0201017},
  eprinttype = {arXiv},
  doi = {10.48550/arXiv.math/0201017},
  url = {http://arxiv.org/abs/math/0201017},
  urldate = {2025-10-22},
  abstract = {For a braided tensor category C and a subcategory K there is a notion of centralizer C\_C(K), which is a full tensor subcategory of C. A pre-modular tensor category is known to be modular in the sense of Turaev iff the center Z\_2(C):=C\_C(C) (not to be confused with the center Z\_1 of a tensor category, related to the quantum double) is trivial, i.e. equivalent to Vect, and dim(C){$<>$}0. Here dim(C)=sum\_i d(X\_i)\textasciicircum 2, the X\_i being the simple objects. We prove the following double centralizer theorem: Let C be a modular category and K a full tensor subcategory closed w.r.t. direct sums, subobjects and duals. Then C\_C(C\_C(K))=K and dim(K)dim(C\_C(K))=dim(C). We give several applications, the most important being the following. If C is modular and K is a full modular subcategory, then also L=C\_C(K) is modular and C is equivalent as a ribbon category to the direct product of K and L. Thus every modular category factorizes (non-uniquely, in general) into prime ones. We study the prime factorizations of the categories D(G)-Mod, where G is a finite abelian group.},
  pubstate = {prepublished},
  keywords = {Mathematics - Category Theory},
  file = {/home/aatmun/Documents/pdfs/Articles/Mueger - 2002 - On the Structure of Modular Categories.pdf;/home/aatmun/Documents/zotero/storage/BFGSIPSG/0201017.html}
}

@online{muegerSubfactorsCategoriesTopology2002,
  title = {From {{Subfactors}} to {{Categories}} and {{Topology I}}. {{Frobenius}} Algebras in and {{Morita}} Equivalence of Tensor Categories},
  author = {Mueger, Michael},
  date = {2002-01-17},
  eprint = {math/0111204},
  eprinttype = {arXiv},
  doi = {10.48550/arXiv.math/0111204},
  url = {http://arxiv.org/abs/math/0111204},
  urldate = {2025-03-03},
  abstract = {We consider certain categorical structures that are implicit in subfactor theory. Making the connection between subfactor theory (at finite index) and category theory explicit sheds light on both subjects. Furthermore, it allows various generalizations of these structures, e.g. to arbitrary ground fields, and the proof of new results about topological invariants in three dimensions. The central notion is that of a Frobenius algebra in a tensor category A, which reduces to the classical notion if A=F-Vect, where F is a field. An object X in A with two-sided dual X\textasciicircum{} gives rise to a Frobenius algebra in A, and under weak additional conditions we prove a converse: There exists a bicategory E with Obj(E)=\{X,Y\} such that End\_E(X,X) is equivalent to A and such that there are J: Y-{$>$}X, J\textasciicircum : X-{$>$}Y producing the given Frobenius algebra. Many properties (additivity, sphericity, semisimplicity,...) of A carry over to E. We define weak monoidal Morita equivalence (wMe) of tensor categories and establish a correspondence between Frobenius algebras in A and tensor categories B wMe A. While considerably weaker than equivalence of tensor categories, weak monoidal Morita equivalence of A and B implies (for A,B semisimple and spherical or *-categories) that A and B have the same dimension, braided equivalent `center' (quantum double) and define the same state sum invariants of closed oriented 3-manifolds as defined by Barrett and Westbury. If H is a finite dimensional semisimple and cosemisimple Hopf algebra then H-mod and H\textasciicircum -mod are wMe. The present formalism permits a fairly complete analysis of the quantum double of a semisimple spherical category, which is the subject of the companion paper math.CT/0111205.},
  pubstate = {prepublished},
  keywords = {Mathematics - Category Theory,Mathematics - Operator Algebras},
  file = {/home/aatmun/Documents/pdfs/Articles/Mueger - 2002 - From Subfactors to Categories and Topology I. Frob.pdf;/home/aatmun/Documents/pdfs/Articles/Mueger - 2002 - From Subfactors to Categories and Topology I. Frobenius algebras in and Morita equivalence of tensor.pdf;/home/aatmun/Documents/zotero/storage/N8WCGVDH/0111204.html}
}

@article{mugerStructureModularCategories2003,
  title = {On the {{Structure}} of {{Modular Categories}}},
  author = {Müger, Michael},
  date = {2003-09},
  journaltitle = {Proceedings of the London Mathematical Society},
  volume = {87},
  number = {2},
  pages = {291--308},
  publisher = {Cambridge University Press},
  issn = {1460-244X, 0024-6115},
  doi = {10.1112/S0024611503014187},
  url = {https://www.cambridge.org/core/journals/proceedings-of-the-london-mathematical-society/article/abs/on-the-structure-of-modular-categories/AC31132AC97B4ADB31C3ADD02D311E06},
  urldate = {2023-09-30},
  abstract = {For a braided tensor category \$\{\textbackslash cal C\}\$ and a subcategory \$\{\textbackslash cal K\}\$ there is a notion of a centralizer \$C\_\{\textbackslash cal C\}(\{\textbackslash cal K\})\$, which is a full tensor subcategory of \$\{\textbackslash cal C\}\$. A pre-modular tensor category is known to be modular in the sense of Turaev if and only if the center \$\{\textbackslash cal Z\}\_2(\{\textbackslash cal C\})\textbackslash equiv C\_\{\textbackslash cal C\}(\{\textbackslash cal C\})\$ (not to be confused with the center \$\{\textbackslash cal Z\}\_1\$ of a tensor category, related to the quantum double) is trivial, that is, consists only of multiples of the tensor unit, and \$\textbackslash dim\{\textbackslash cal C\}\textbackslash ne 0\$. Here \$\textbackslash dim\{\textbackslash cal C\} = \textbackslash sum\_i d(X\_i)\textasciicircum 2\$, the \$X\_i\$ being the simple objects.We prove several structural properties of modular categories. Our main technical tool is the following double centralizer theorem. Let \$\{\textbackslash cal C\}\$ be a modular category and \$\{\textbackslash cal K\}\$ a full tensor subcategory closed with respect to direct sums, subobjects and duals. Then \$C\_\{\textbackslash cal C\}(C\_\{\textbackslash cal C\}(\{\textbackslash cal K\})) = \{\textbackslash cal K\}\$ and \$\textbackslash dim\{\textbackslash cal K\}\textbackslash cdot\textbackslash dim C\_\{\textbackslash cal C\}(\{\textbackslash cal K\}) = \textbackslash dim\{\textbackslash cal C\}\$.We give several applications.(1)\enspace If \$\{\textbackslash cal C\}\$ is modular and \$\{\textbackslash cal K\}\$ is a full modular subcategory, then \$\{\textbackslash cal L\}=C\_\{\textbackslash cal C\}(\{\textbackslash cal K\})\$ is also modular and \$\{\textbackslash cal C\}\$ is equivalent as a ribbon category to the direct product: \$\{\textbackslash cal C\}\textbackslash simeq\{\textbackslash cal K\}\textbackslash boxtimes\{\textbackslash cal L\}\$. Thus every modular category factorizes (non-uniquely, in general) into prime modular categories. We study the prime factorizations of the categories \$D(G)\$-Mod, where \$G\$ is a finite abelian group.(2)\enspace If \$\{\textbackslash cal C\}\$ is a modular \$*\$-category and \$\{\textbackslash cal K\}\$ is a full tensor subcategory then \$\textbackslash dim\{\textbackslash cal C\}\textbackslash ge\textbackslash dim\{\textbackslash cal K\}\textbackslash cdot\textbackslash dim \{\textbackslash cal Z\}\_2(\{\textbackslash cal K\})\$. We give examples where the bound is attained and conjecture that every pre-modular \$\{\textbackslash cal K\}\$ can be embedded fully into a modular category \$\{\textbackslash cal C\}\$ with \$\textbackslash dim\{\textbackslash cal C\}=\textbackslash dim\{\textbackslash cal K\}\textbackslash cdot\textbackslash dim \{\textbackslash cal Z\}\_2(\{\textbackslash cal K\})\$.(3)\enspace For every finite group \$G\$ there is a braided tensor \$*\$-category \$\{\textbackslash cal C\}\$ such that \$\{\textbackslash cal Z\}\_2(\{\textbackslash cal C\})\textbackslash simeq\textbackslash mbox\{Rep\}\textbackslash,G\$ and the modular closure/modularization \$\textbackslash overline\{\textbackslash cal C\}\$ is non-trivial.},
  langid = {english},
  keywords = {18D10,braided monoidal categories,modular categories},
  file = {/home/aatmun/Documents/bib/pdfs/Müger_2003_On the Structure of Modular Categories.pdf;/home/aatmun/Documents/pdfs/Articles/Müger - 2003 - On the Structure of Modular Categories.pdf;/home/aatmun/Documents/zotero/storage/WCXWFN8Z/S0024611503014187.html}
}

