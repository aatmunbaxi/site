  urldate = {2026-02-25},
  abstract = {A braid representation is a monoidal functor from the braid category \$\textbackslash mathsf\{B\}\$, for example given by a solution to the constant Yang-Baxter equation. Given a monoidal category \$\textbackslash mathsf\{C\}\$ with \$ob(\textbackslash mathsf\{C\})=\textbackslash mathbb\{N\}\$, a rank-\$N\$ charge-conserving representation (or spin-chain representation) is a strict monoidal functor \$F\$ from \$\textbackslash mathsf\{C\}\$ to the category \$\textbackslash mathrm\{Match\}\textasciicircum N\$ of rank-\$N\$ charge-conserving matrices that is natural in the sense that \$F(1)=1\$. In this work we construct all spin-chain braid representations, and classify up to suitable notions of isomorphism.},
