  file = {/home/aatmun/Documents/pdfs/Articles/Gelaki and Nikshych - 2008 - Nilpotent fusion categories 3.pdf;/home/aatmun/Documents/pdfs/Articles/Gelaki and Nikshych - 2008 - Nilpotent fusion categories 4.pdf;/home/aatmun/Documents/pdfs/Articles/Gelaki and Nikshych - 2008 - Nilpotent fusion categories.pdf}
