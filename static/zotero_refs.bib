  doi = {10.1007/s00220-016-2748-y},
  url = {http://arxiv.org/abs/1602.05936},
  urldate = {2024-06-12},
  abstract = {A finite bosonic or fermionic symmetry can be described uniquely by a symmetric fusion category \$\textbackslash mathcal\{E\}\$. In this work, we propose that 2+1D topological/SPT orders with a fixed finite symmetry \$\textbackslash mathcal\{E\}\$ are classified, up to \$E\_8\$ quantum Hall states, by the unitary modular tensor categories \$\textbackslash mathcal\{C\}\$ over \$\textbackslash mathcal\{E\}\$ and the modular extensions of each \$\textbackslash mathcal\{C\}\$. In the case \$\textbackslash mathcal\{C\}=\textbackslash mathcal\{E\}\$, we prove that the set \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{E\})\$ of all modular extensions of \$\textbackslash mathcal\{E\}\$ has a natural structure of a finite abelian group. We also prove that the set \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{C\})\$ of all modular extensions of \$\textbackslash mathcal\{C\}\$, if not empty, is equipped with a natural \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{E\})\$-action that is free and transitive. Namely, the set \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{C\})\$ is an \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{E\})\$-torsor. As special cases, we explain in details how the group \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{E\})\$ recovers the well-known group-cohomology classification of the 2+1D bosonic SPT orders and Kitaev's 16 fold ways. We also discuss briefly the behavior of the group \$\textbackslash mathcal\{M\}\_\{ext\}(\textbackslash mathcal\{E\})\$ under the symmetry-breaking processes and its relation to Witt groups.},
  keywords = {Condensed Matter - Strongly Correlated Electrons,Mathematics - Category Theory,Mathematics - Quantum Algebra},
  file = {/home/aatmun/Documents/bib/pdfs/Lan et al_2017_Modular extensions of unitary braided fusion categories and 2+1D.pdf;/home/aatmun/Documents/pdfs/Articles/Lan et al. - 2017 - Modular extensions of unitary braided fusion categ.pdf;/home/aatmun/Documents/pdfs/Articles/Lan et al. - 2017 - Modular extensions of unitary braided fusion categories and 2+1D topologicalSPT orders with symmetr.pdf;/home/aatmun/Documents/zotero/storage/SWZUY9RN/1602.html}
}

