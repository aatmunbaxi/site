  doi = {10.48550/arXiv.2010.00847},
  url = {http://arxiv.org/abs/2010.00847},
  urldate = {2024-07-16},
  abstract = {For an abelian group \$ A \$, we study a close connection between braided crossed \$ A \$-categories with a trivialization of the \$ A \$-action and \$ A \$-graded braided tensor categories. Additionally, we prove that the obstruction to the existence of a trivialization of a categorical group action \$T\$ on a monoidal category \$\textbackslash mathcal\{C\}\$ is given by an element \$O(T)\textbackslash in H\textasciicircum 2(G,\textbackslash operatorname\{Aut\}\_\textbackslash otimes(\textbackslash operatorname\{Id\}\_\{\textbackslash mathcal\{C\}\}))\$. In the case that \$O(T)=0\$, the set of obstructions form a torsor over \$\textbackslash operatorname\{Hom\}(G,\textbackslash operatorname\{Aut\}\_\textbackslash otimes(\textbackslash operatorname\{Id\}\_\{\textbackslash mathcal\{C\}\}))\$, where \$\textbackslash operatorname\{Aut\}\_\textbackslash otimes(\textbackslash operatorname\{Id\}\_\{\textbackslash mathcal\{C\}\})\$ is the abelian group of tensor natural automorphisms of the identity. The cohomological interpretation of trivializations, together with the homotopical classification of (faithfully graded) braided \$A\$-crossed tensor categories developed in arXiv:0909.3140, allows us to provide a method for the construction of faithfully \$A\$-graded braided tensor categories. We work out two examples. First, we compute the obstruction to the existence of trivializations for the braided crossed category associated with a pointed semisimple tensor category. In the second example, we compute explicit formulas for the braided \$\textbackslash mathbb\{Z\}/2\$-crossed structures over Tambara-Yamagami fusion categories and, consequently, a conceptual interpretation of the results in arXiv:math/0011037 about the classification of braidings over Tambara-Yamagami categories.},
  pubstate = {prepublished},
  keywords = {Mathematics - Quantum Algebra},
  file = {/home/aatmun/Documents/bib/pdfs/Galindo_2020_Trivializing group actions on braided crossed tensor categories and graded.pdf;/home/aatmun/Documents/pdfs/Articles/Galindo - 2020 - Trivializing group actions on braided crossed tens.pdf;/home/aatmun/Documents/pdfs/Articles/Galindo - 2020 - Trivializing group actions on braided crossed tensor categories and graded braided tensor categories.pdf}
}

