  doi = {10.48550/arXiv.1910.03178},
  url = {http://arxiv.org/abs/1910.03178},
  urldate = {2024-07-15},
  abstract = {For a braided fusion category \$\textbackslash mathcal\{V\}\$, a \$\textbackslash mathcal\{V\}\$-fusion category is a fusion category \$\textbackslash mathcal\{C\}\$ equipped with a braided monoidal functor \$\textbackslash mathcal\{F\}:\textbackslash mathcal\{V\} \textbackslash to Z(\textbackslash mathcal\{C\})\$. Given a fixed \$\textbackslash mathcal\{V\}\$-fusion category \$(\textbackslash mathcal\{C\}, \textbackslash mathcal\{F\})\$ and a fixed \$G\$-graded extension \$\textbackslash mathcal\{C\}\textbackslash subseteq \textbackslash mathcal\{D\}\$ as an ordinary fusion category, we characterize the enrichments \$\textbackslash widetilde\{\textbackslash mathcal\{F\}\}:\textbackslash mathcal\{V\} \textbackslash to Z(\textbackslash mathcal\{D\})\$ of \$\textbackslash mathcal\{D\}\$ which are compatible with the enrichment of \$\textbackslash mathcal\{C\}\$. We show that G-crossed extensions of a braided fusion category \$\textbackslash mathcal\{C\}\$ are G-extensions of the canonical enrichment of \$\textbackslash mathcal\{C\}\$ over itself. As an application, we parameterize the set of \$G\$-crossed braidings on a fixed \$G\$-graded fusion category in terms of certain subcategories of its center, extending Nikshych's classification of the braidings on a fusion category.},
  pubstate = {prepublished},
  keywords = {18D20 18M20,Mathematics - Category Theory,Mathematics - Quantum Algebra},
  file = {/home/aatmun/Documents/bib/pdfs/Jones et al_2021_Extension theory for braided-enriched fusion categories.pdf}
}

