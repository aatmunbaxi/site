  pages = {1043--1064},
  issn = {1432-0916},
  doi = {10.1007/s00220-016-2633-8},
  url = {https://doi.org/10.1007/s00220-016-2633-8},
  urldate = {2023-11-13},
  abstract = {Topological order of a topological phase of matter in two spacial dimensions is encoded by a unitary modular (tensor) category (UMC). A group symmetry of the topological phase induces a group symmetry of its corresponding UMC. Gauging is a well-known theoretical tool to promote a global symmetry to a local gauge symmetry. We give a mathematical formulation of gauging in terms of higher category formalism. Roughly, given a UMC with a symmetry group G, gauging is a 2-step process: first extend the UMC to a G-crossed braided fusion category and then take the equivariantization of the resulting category. Gauging can tell whether or not two enriched topological phases of matter are different, and also provides a way to construct new UMCs out of old ones. We derive a formula for the \$\$\{H\textasciicircum 4\}\$\$-obstruction, prove some properties of gauging, and carry out gauging for two concrete examples.},
  langid = {english},
  keywords = {Cohomology Class,Fusion Rule,Global Symmetry,Mathematics - Quantum Algebra,Tensor Category,Topological Order},
  file = {/home/aatmun/Documents/bib/pdfs/Cui et al_2016_On Gauging Symmetry of Modular Categories2.pdf;/home/aatmun/Documents/pdfs/Articles/Cui et al. - 2016 - On Gauging Symmetry of Modular Categories.pdf;/home/aatmun/Documents/zotero/storage/T6HUJ6LK/1510.html}
}

