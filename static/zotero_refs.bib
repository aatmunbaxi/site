@online{decoppetFiber2FunctorsTambaraYamagami2024,
  title = {Fiber 2-{{Functors}} and {{Tambara-Yamagami Fusion}} 2-{{Categories}}},
  author = {Décoppet, Thibault D. and Yu, Matthew},
  date = {2024-12-10},
  eprint = {2306.08117},
